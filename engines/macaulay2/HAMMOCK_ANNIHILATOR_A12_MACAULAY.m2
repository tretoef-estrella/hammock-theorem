  {{1,7},{2,5},{3,4},{6,8}},
  {{1,7},{2,5},{3,6},{4,8}},
  {{1,7},{2,5},{3,8},{4,6}},
  {{1,7},{2,6},{3,4},{5,8}},
  {{1,7},{2,6},{3,5},{4,8}},
  {{1,7},{2,6},{3,8},{4,5}},
  {{1,7},{2,8},{3,4},{5,6}},
  {{1,7},{2,8},{3,5},{4,6}},
  {{1,7},{2,8},{3,6},{4,5}},
  {{1,8},{2,3},{4,5},{6,7}},
  {{1,8},{2,3},{4,6},{5,7}},
  {{1,8},{2,3},{4,7},{5,6}},
  {{1,8},{2,4},{3,5},{6,7}},
  {{1,8},{2,4},{3,6},{5,7}},
  {{1,8},{2,4},{3,7},{5,6}},
  {{1,8},{2,5},{3,4},{6,7}},
  {{1,8},{2,5},{3,6},{4,7}},
  {{1,8},{2,5},{3,7},{4,6}},
  {{1,8},{2,6},{3,4},{5,7}},
  {{1,8},{2,6},{3,5},{4,7}},
  {{1,8},{2,6},{3,7},{4,5}},
  {{1,8},{2,7},{3,4},{5,6}},
  {{1,8},{2,7},{3,5},{4,6}},
  {{1,8},{2,7},{3,6},{4,5}}
};
-- linear ideal of a sheet V_J : (x_a + x_b) for each pair
sheetIdeal = (J) -> ideal apply(J, pr -> S_(pr#0-1) + S_(pr#1-1));
-- swap hyperplanes of J (factors of Pi_J): x_i +/- x_j for i in pair m, j in pair n, m<n
swapForms = (J) -> flatten flatten apply(#J-1, m -> apply(toList(m+1..#J-1), n ->
    flatten apply({ {J#m#0,J#n#0},{J#m#0,J#n#1},{J#m#1,J#n#0},{J#m#1,J#n#1} }, ij ->
      { S_(ij#0-1) + S_(ij#1-1), S_(ij#0-1) - S_(ij#1-1) })));
N = #matchings;
sepOK = true; total = 0; found = 0;
for ji from 0 to N-1 do (
  sf := swapForms(matchings#ji);
  for jp from 0 to N-1 do (
    if jp == ji then continue;
    total = total + 1;
    Ijp := sheetIdeal(matchings#jp);
    -- a separator exists iff some swap form of J reduces to 0 modulo I_{J'}
    if any(sf, f -> (f % Ijp) == 0) then found = found + 1 else sepOK = false;
  );
);
stdio << "=====================================================" << endl;
stdio << " Hammock FINAL — Macaulay2 byte: annihilator first class a_12" << endl;
stdio << "=====================================================" << endl;
stdio << "sheets N = " << N << "  (want 105)" << endl;
stdio << "ordered pairs with a separating swap hyperplane: " << found << " / " << total << endl;
stdio << "Covering Lemma holds over all pairs: " << sepOK << endl;
gate = (N == 105) and sepOK and (found == total);
if gate then (
  stdio << "GATE true -> lifting polynomials X_J exist for every sheet -> Phi_12 onto per summand" << endl;
  stdio << "         -> a_12 = 105 (one annihilator class per sheet), measured in Macaulay2 over F3." << endl;
  ) else stdio << "*** GATE FAILED — investigate (Ley 26). ***" << endl;
stdio << "=====================================================" << endl;
